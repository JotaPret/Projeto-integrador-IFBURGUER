# MySQL Configuration
DATABASE_URL="mysql://root:@localhost:3306/ifburguer"

# JWT Configuration (opcional, para futuras implementações)
JWT_SECRET="seu_jwt_secret_aqui"
JWT_EXPIRATION="7d"

# App Configuration
NODE_ENV="development"
PORT=3334

# CORS (frontend)
FRONTEND_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Admin seed (opcional)
# Se definido, `npm run prisma:seed` garante que esse usuário exista com role ADMIN.
ADMIN_EMAIL="admin@ifburguer.com"
ADMIN_PASSWORD="123456"
ADMIN_NOME="Administrador"
ADMIN_TELEFONE=""
